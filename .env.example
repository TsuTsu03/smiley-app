# ════════════════════════════════════════════════════════════════
#  Smiley — environment variables
#  Copy this file to `.env.local` and fill in real values.
#  NEVER commit `.env.local`.
# ════════════════════════════════════════════════════════════════

# ─── Supabase (REQUIRED) ─────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key   # server-only, keep secret

# Public URL of the app (used for PayMongo redirects). Production:
NEXT_PUBLIC_APP_URL=https://smileyhq.it.com
# Local dev: NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── PayMongo billing (Philippine payment gateway) ───────────────
# Dashboard → Developers → API Keys
PAYMONGO_SECRET_KEY=sk_test_xxx
PAYMONGO_WEBHOOK_SECRET=whsk_xxx               # returned when you create the webhook
# Monthly plan prices in CENTAVOS (₱1,500 = 150000). Multi-Clinic is per branch.
PAYMONGO_PRICE_STARTER=150000
PAYMONGO_PRICE_GROWTH=350000
PAYMONGO_PRICE_MULTICLINIC=300000

# ─── Email reminders (Brevo — free, no domain needed) ────────────
# Free key at https://app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxx
BREVO_SENDER_EMAIL=noreply@smileyhq.it.com   # domain must be verified in Brevo (Senders → Domains)
BREVO_SENDER_NAME=Smiley                     # default display name (clinic name overrides per-email)

# ─── Scheduled reminder cron ─────────────────────────────────────
# Any long random string. Vercel Cron sends this automatically as a Bearer token.
CRON_SECRET=generate-a-long-random-string

# ─── AI assistant (Groq — free, fast) ────────────────────────────
# Free key at https://console.groq.com (no credit card required)
GROQ_API_KEY=gsk_xxx
# Optional model override (defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── Rate limiting (Upstash Redis — free, serverless) ────────────
# Free DB at https://console.upstash.com → Redis → REST API.
# Without these, an in-memory fallback is used (fine for dev; NOT shared
# across serverless instances — set these for real protection in production).
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx
